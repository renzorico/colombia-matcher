# Comma-separated list of allowed CORS origins.
# In development, http://localhost:3000 is always allowed by default.
# In production, set this to your Vercel frontend URL.
#
# Example:
# CORS_ORIGINS=https://colombia-matcher.vercel.app
CORS_ORIGINS=

# PORT is injected automatically by Railway and Render — never set this manually.
# Listed here only for documentation purposes.
# PORT=8000
